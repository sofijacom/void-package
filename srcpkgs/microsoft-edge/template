do_install() {
	# Copy files
	vcopy "*" /

	# Remove cronjob
	rm -f "${DESTDIR}/etc/cron.daily/microsoft-edge"

	# Install the icon
	vmkdir usr/share/pixmaps
	vinstall opt/microsoft/msedge/product_logo_128.png 644 usr/share/pixmaps microsoft-edge.png
}
