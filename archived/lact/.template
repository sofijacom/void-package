# Template file for 'lact'
pkgname=lact
version=${VERSION}
revision=1
build_style=cargo
hostmakedepends="pkg-config clang"
makedepends="libdrm-devel glib-devel gtk4-devel"
depends="hwids"
short_desc="AMD GPU Control Utility for Linux"
maintainer="Sofiya <sofiya@v.com>"
license="MIT"
homepage="https://github.com/ilya-zlobintsev/LACT"
distfiles="https://github.com/ilya-zlobintsev/LACT/archive/v${version}.tar.gz"
checksum=${SHA256}

do_install() {
	vbin target/x86_64-unknown-linux-gnu/release/lact
	vsv lactd
	vlicense LICENSE
	vinstall res/io.github.ilya_zlobintsev.LACT.desktop 644 usr/share/applications
	vinstall res/io.github.ilya_zlobintsev.LACT.png 644 usr/share/icons/hicolor/scalable/apps
}
