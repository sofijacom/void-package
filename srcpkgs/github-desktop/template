# Template file for 'github-desktop'
pkgname=github-desktop
version=release-3.4.13-linux1
revision=1
_channel=linux1
archs="x86_64"
hostmakedepends="curl tar xz python3 python3-html2text python3-setuptools"
depends="gtk+3"
short_desc="Simple collaboration from your desktop"
maintainer="Sofiya <Sofiya@v.org>"
license="custom:github-desktop"
homepage="https://github.com/shiftkey/desktop"
nopie=yes

_baseUrl="https://github.com/shiftkey/desktop/releases/latest/download/"
_filename="GitHubDesktop-linux-amd64-${version}-${_channel}.deb"
_githubUrl="${_baseUrl}/${_filename}"

distfiles="$_githubUrl"
checksum=0019dfc4b32d63c1392aa264aed2253c1e0c2fb09216f8e2cc269bbfb8bb49b5

do_extract() {
	mkdir -p ${DESTDIR}
	ar x ${XBPS_SRCDISTDIR}/github-desktop-${version}/${_filename}

}

do_install() {
	tar xf data.tar.xz -C ${DESTDIR}

}
