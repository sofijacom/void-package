# Template file for 'ly'
pkgname=ly
version=1.4.1
revision=1
archs="x86_64"
build_style=zig-build
hostmakedepends="pkg-config zig-0.16 git"
makedepends="pam-devel libxcb-devel glibc-devel"
depends="xorg-server xauth brightnessctl"
short_desc="Ly is a lightweight TUI (ncurses-like) display manager for Linux and BSD."
maintainer="Sofiya <sofiya@v.org>"
license="WTFPL"
homepage="https://codeberg.org/fairyglade/ly"
distfiles="https://codeberg.org/fairyglade/ly/archive/v${version}.tar.gz"
checksum=4d1c10422e6c5b8d5a795150e4c364c82404f900c1a04318b83fe8d81fade58b

conf_files="
 /etc/ly/config.ini
 /etc/pam.d/ly
 /etc/pam.d/ly-autologin"
nopie=yes

do_build() {
	zig build installexe -Dinit_system=runit
}

do_install() {
	vbin zig-out/bin/ly
	vsv ly
	vmkdir etc/sv/ly
	vinstall res/config.ini 644 etc/ly
	vinstall res/pam.d/ly-linux 644 etc/pam.d ly
	vinstall res/pam.d/ly-linux-autologin 644 etc/pam.d ly-autologin
	vinstall res/setup.sh 755 etc/ly
	vcopy res/lang etc/ly
	vcopy res/custom-sessions etc/ly
}

post_install() {
  vlicense license.md
}
